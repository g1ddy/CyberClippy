<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Clippy.Core.ViewModels.Messages"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="100"
             x:Class="Clippy.Avalonia.Controls.ClippyMessage"
             x:DataType="vm:ClippyMessageViewModel">
    <Grid Margin="{StaticResource MessageMargin}" HorizontalAlignment="Left">
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Padding="{StaticResource DefaultPadding}">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding StreamingText}"
                           IsVisible="{Binding IsStreaming}"
                           TextWrapping="Wrap"
                           MaxWidth="{StaticResource MessageMaxWidth}"/>
                 <TextBlock Text="{Binding MessageText}"
                           IsVisible="{Binding !IsStreaming}"
                           TextWrapping="Wrap"
                           MaxWidth="{StaticResource MessageMaxWidth}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
