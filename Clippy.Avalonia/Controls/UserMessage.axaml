<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Clippy.Core.ViewModels.Messages"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="100"
             x:Class="Clippy.Avalonia.Controls.UserMessage"
             x:DataType="vm:UserMessageViewModel">
    <Grid Margin="0,8,0,8" HorizontalAlignment="Right">
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8"
                Padding="12">
            <TextBlock Text="{Binding MessageText}"
                       TextWrapping="Wrap"
                       MaxWidth="300"
                       HorizontalAlignment="Left"/>
        </Border>
        <!-- Triangle mimic could go here, omitting for simplicity as per plan -->
    </Grid>
</UserControl>
