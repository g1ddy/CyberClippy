<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Clippy.Core.ViewModels"
        xmlns:vmm="using:Clippy.Core.ViewModels.Messages"
        xmlns:controls="using:Clippy.Avalonia.Controls"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
        x:Class="Clippy.Avalonia.MainWindow"
        x:DataType="vm:ClippyViewModel"
        Title="Clippy"
        TransparencyLevelHint="Mica, AcrylicBlur, Blur, Transparent, None"
        Background="Transparent"
        Topmost="True"
        ExtendClientAreaToDecorationsHint="True">

    <Grid RowDefinitions="*,100,Auto" Margin="{StaticResource ChatAreaMargin}">

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding IsClippyEnabled}">
            <ItemsControl ItemsSource="{Binding MessagesVM}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="vmm:ClippyMessageViewModel">
                        <controls:ClippyMessage />
                    </DataTemplate>
                    <DataTemplate DataType="vmm:UserMessageViewModel">
                        <controls:UserMessage />
                    </DataTemplate>
                    <DataTemplate DataType="vmm:SystemMessageViewModel">
                        <controls:SystemMessage />
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>

        <!-- Mascot Area -->
        <Grid Grid.Row="1" Margin="0,-16,0,0">
            <ToggleButton Name="ClippyToggle" IsChecked="{Binding IsClippyEnabled, Mode=TwoWay}"
                          HorizontalAlignment="Right"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                <ToggleButton.Styles>
                    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ToggleButton.Styles>
                <ToggleButton.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuItem Header="Pin to top" x:Name="PinToTopMenuItem">
                            <MenuItem.Icon>
                                <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Hide" Click="Hide_Click">
                            <MenuItem.Icon>
                                <PathIcon Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Settings" Click="Settings_Click">
                            <MenuItem.Icon>
                                <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="-" />
                        <MenuItem Header="Exit" Click="Exit_Click">
                            <MenuItem.Icon>
                                <PathIcon Data="M19,3H5C3.89,3 3,3.89 3,5V9H5V5H19V19H5V15H3V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M10.08,15.58L11.5,17L16.5,12L11.5,7L10.08,8.41L12.67,11H3V13H12.67L10.08,15.58Z" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuFlyout>
                </ToggleButton.Flyout>
                <Image Source="avares://Clippy.Avalonia/Assets/Clippy.png" Height="100" Width="100"/>
            </ToggleButton>
        </Grid>

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="{StaticResource InputAreaMargin}"
              IsVisible="{Binding IsClippyEnabled}">
             <Border Grid.Column="0"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    Padding="{StaticResource SmallPadding}">
                <TextBox Name="InputTextBox"
                         Text="{Binding CurrentText, Mode=TwoWay}"
                         Watermark="Ask me anything.."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="{StaticResource InputMaxHeight}"
                         BorderThickness="0"
                         Background="Transparent"
                         KeyDown="InputTextBox_KeyDown">
                </TextBox>
            </Border>

            <Button Grid.Column="1"
                    Command="{Binding SendPromptCommand}"
                    Margin="{StaticResource SendButtonMargin}"
                    VerticalAlignment="Bottom"
                    Padding="{StaticResource ButtonPadding}">
                <PathIcon Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" Width="20" Height="20"/>
            </Button>
        </Grid>
    </Grid>
</Window>
