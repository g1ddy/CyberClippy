<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Clippy.Avalonia.Converters"
             xmlns:sys="using:System"
             x:Class="Clippy.Avalonia.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />

        <Thickness x:Key="ChatAreaMargin">12,30,12,12</Thickness>
        <Thickness x:Key="InputAreaMargin">0,12,0,0</Thickness>
        <Thickness x:Key="MessageMargin">0,8,0,8</Thickness>
        <Thickness x:Key="SendButtonMargin">8,0,0,0</Thickness>
        <Thickness x:Key="DefaultPadding">12</Thickness>
        <Thickness x:Key="SmallPadding">4</Thickness>
        <Thickness x:Key="ButtonPadding">10</Thickness>
        <CornerRadius x:Key="DefaultCornerRadius">8</CornerRadius>
        <sys:Double x:Key="MessageMaxWidth">300</sys:Double>
        <sys:Double x:Key="InputMaxHeight">100</sys:Double>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button.ToolbarButton">
             <Setter Property="Background" Value="Transparent"/>
             <Setter Property="BorderThickness" Value="0"/>
             <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="TextBox.GlowTextBox">
            <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Application.Styles>
</Application>